{
  "name": "bigorec",
  "version": "0.1.0",
  "description": "Download and record Bigo Live streams",
  "license": "MIT",
  "bin": {
    "bigorec": "./dist/bin/bigorec.mjs"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.mts"
    }
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src/ bin/",
    "format": "biome check --write src/ bin/",
    "format:check": "biome check src/ bin/"
  },
  "dependencies": {
    "citty": "^0.1.6",
    "consola": "^3.2.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.2",
    "@types/node": "^26.1.0",
    "lefthook": "^2.1.9",
    "tsdown": "^0.22.3",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=18"
  }
}
